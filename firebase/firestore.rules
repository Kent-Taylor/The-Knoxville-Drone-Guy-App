rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isValidClientProfile(userId) {
      return isOwner(userId)
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.role == 'client';
    }

    function isValidShootRequestCreate() {
      return signedIn()
        && request.resource.data.keys().hasAll([
          'clientId',
          'clientName',
          'requesterName',
          'title',
          'requestedWhen',
          'requestedDate',
          'projectAddress',
          'homeBaseAddress',
          'services',
          'details',
          'isRecurring',
          'status',
          'createdAt'
        ])
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.clientName is string
        && request.resource.data.requesterName is string
        && request.resource.data.title is string
        && request.resource.data.requestedWhen is string
        && request.resource.data.requestedDate is string
        && request.resource.data.projectAddress is string
        && request.resource.data.homeBaseAddress is string
        && request.resource.data.services is list
        && request.resource.data.services.size() > 0
        && request.resource.data.details is string
        && request.resource.data.isRecurring is bool
        && request.resource.data.status == 'requested'
        && request.resource.data.createdAt is number;
    }

    function isValidShootRequestClientUpdate() {
      return signedIn()
        && resource.data.clientId == request.auth.uid
        && resource.data.status != 'accepted'
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.status == resource.data.status
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.title is string
        && request.resource.data.requestedWhen is string
        && request.resource.data.projectAddress is string
        && request.resource.data.details is string;
    }

    function isChatThreadOwner() {
      return signedIn() && resource.data.clientId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isAdmin() || isValidClientProfile(userId);
      allow update: if isAdmin() || (isValidClientProfile(userId) && resource.data.role == 'client');
      allow delete: if isAdmin();
    }

    match /chatThreads/{threadId} {
      allow read: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow create: if isAdmin()
        || (signedIn() && request.resource.data.clientId == request.auth.uid);
      allow update: if isAdmin()
        || (
          isChatThreadOwner()
          && request.resource.data.clientId == resource.data.clientId
          && request.resource.data.clientName == resource.data.clientName
        );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || get(/databases/$(database)/documents/chatThreads/$(threadId)).data.clientId == request.auth.uid;
        allow create: if (isAdmin() || get(/databases/$(database)/documents/chatThreads/$(threadId)).data.clientId == request.auth.uid)
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.body is string
          && request.resource.data.createdAt is number;
        allow update, delete: if isAdmin();
      }
    }

    match /jobs/{jobId} {
      allow read: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow create, update, delete: if isAdmin();

      match /updates/{updateId} {
        allow read: if isAdmin() || get(/databases/$(database)/documents/jobs/$(jobId)).data.clientId == request.auth.uid;
        allow create, update, delete: if isAdmin();
      }

      match /private/{docId} {
        allow read, write: if isAdmin();
      }
    }

    match /shootRequests/{requestId} {
      allow read: if isAdmin() || resource.data.clientId == request.auth.uid;
      allow create: if isValidShootRequestCreate();
      allow update: if isAdmin() || isValidShootRequestClientUpdate();
      allow delete: if isAdmin();
    }
  }
}
